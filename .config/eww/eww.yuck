(include "./modules/touch.yuck")

(defwindow sound-window
  :monitor    0 ;; Optional for X11
  :stacking   "fg"
  :windowtype "normal"
  :wm-ignore  true
  :geometry   (geometry :x "20px" :y "5px" :anchor "top right")
  (sound-controls))

(defwindow brightness-window
  :monitor    0 ;; Optional for X11
  :stacking   "fg"
  :windowtype "normal"
  :wm-ignore   true
  :geometry    (geometry :x "16%" :y "5px" :anchor "top left")
  (brightness-controls))
