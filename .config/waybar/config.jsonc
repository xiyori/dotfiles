{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    //"gtk-layer-shell": "false",
    //"output": "!DP-1",
    "height": 50, // Waybar height (to be removed for auto height)
    // "width": 2560, // Waybar width
    "spacing": 0, // Gaps between modules (0px) Adjusted in the css
    "margin-top": 0,
    //"margin-bottom":-10,
    "margin-left": 10,
    "margin-right": 10,
    // Choose the order of the modules
    "modules-left": [
        "custom/launcher",
        "cpu",
        "memory",
        "temperature#cpu",
        // "temperature#gpu",
        "disk#default",
        // "disk#system",
        // "disk#data",
        "battery",
        "backlight",
        // "custom/fancontrol",
        "custom/monitor",
        "hyprland/workspaces"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "tray",
        "custom/notifications",
        "custom/updates",
        // "network",
        "custom/autogain",
        "custom/soundprofile",
        "custom/sound",
        // "wireplumber",
        "hyprland/language",
        "custom/weather",
        "clock",
        // "custom/cycle_wall",
        // "custom/clipboard",
        "custom/power"
        // "custom/custom"
    ],
    "custom/launcher": {
        "format": "{}",
        "tooltip": true,
        "exec": "echo '{\"text\":\"َ°£‡\",\"tooltip\":\"Launcher\"}'",
        "return-type": "json",
        "on-click": "pkill rofi || rofi -show drun"
    },
    "hyprland/workspaces": {
        // "format": "{icon} {name}",
        "sort-by": "id",
        "disable-scroll": false,
        "format": "{icon}",
        "format-icons": {
            "Music": "َ°ژ‡",
            "Carla": "َ°™½",
            "Telegram": "îˆ—",
            // "active": "ï„‘",
            "default": "ï„‘",
            "1": "َ°² ",
            "2": "َ°²¢",
            "3": "َ°²¤",
            "4": "َ°²¦",
            "5": "َ°²¨",
            "6": "َ°²ھ",
            "7": "َ°²¬",
            "8": "َ°²®",
            "9": "َ°²°",
            "10": "َ°؟¬"
        },
        "on-scroll-up": "~/.scripts/workspace_swipe.py prev",
        "on-scroll-down": "~/.scripts/workspace_swipe.py next",
        "on-click": "activate"
        /*"workspace-taskbar": {
            "enable": true,
            "update-active-window": true
        },*/
        /*"format": "{windows}",
        "window-rewrite-default": "ï„‘",
        "window-rewrite": {
            "class<kitty> title<rmpc>": "َ°ژ‡",
            "class<carla>": "َ°™½",
            "title<.*youtube.*>": "ï…ھ",
            "class<firefox|librewolf>": "َ°ˆ¹",
            // "class<firefox> title<.*github.*>": "ï„“", // Windows whose class is "firefox" and title contains "github". Note that "class" always comes first.
            "class<thunar>": "ïپ¼",
            "class<Alacritty>": "î‍•",
            "title<.* - (.*) - VSCodium>": "codium $1"  // captures part of the window title and formats it into output
        }*/
    },
    "cpu": {
        "format": "ï’¼ {usage}%",
        "tooltip": true,
        "on-click": "alacritty -e btop",
        "interval": 2
    },
    "memory": {
        "format": "ï‹› {}%",
        "tooltip": true,
        "on-click": "alacritty -e btop",
        "interval": 2
    },
    "temperature#cpu": {
        // "thermal-zone": 2,
        "hwmon-path": "/tmp/hwmon4/temp1_input",
        "critical-threshold": 75,
        "format-critical": "<span color='#F38BA8'>{icon} {temperatureC}آ°C</span>",
        "format": "{icon} {temperatureC}آ°C",
        "format-icons": [
            "ï‹‹",
            "ï‹‰",
            "ï‹‡"
        ],
        "tooltip": true,
        "on-click": "alacritty -e nvtop",
        "interval": 2
    },
    "temperature#gpu": {
        // "thermal-zone": 2,
        "hwmon-path": "/tmp/monitor-temp/temp_gpu",
        "critical-threshold": 70,
        "format-critical": "<span color='#F38BA8'>{icon} {temperatureC}آ°C</span>",
        "format": "{icon} {temperatureC}آ°C",
        "format-icons": [
            "î¾§"
        ],
        "tooltip": true,
        "on-click": "alacritty -e nvtop",
        "interval": 2
    },
    "disk#default": {
        "format": "ï‚  {percentage_used}%",  // ({free})",
        "tooltip": true,
        //"on-click": "alacritty -e btop",
        "interval": 2
    },
    "disk#system": {
        "format": "ï‚  {percentage_used}%,",  // ({free})",
        "tooltip": true,
        //"on-click": "alacritty -e btop",
        "interval": 2
    },
    "disk#data": {
        "format": "{percentage_used}%",  // ({free})",
        "tooltip": true,
        //"on-click": "alacritty -e btop",
        "interval": 2,
        "path": "/mnt/data"
    },
    "custom/monitor": {
        // "scroll-step": 1, // %, can be a float
        "format": "{}", // {format_source}
        "tooltip": true,
        "exec": "cat /tmp/custom_monitor_waybar",
        "return-type": "json",
        "on-click": "~/.scripts/mirror.sh",
        "on-click-right": "~/.scripts/external.sh",
        "signal": 3
    },
    "custom/fancontrol": {
        // "scroll-step": 1, // %, can be a float
        "format": "{}", // {format_source}
        "interval": 60,
        "tooltip": true,
        "exec": "~/.scripts/fancontrol_status.sh",
        "return-type": "json"
    },
    "custom/updates": {
        "format": "{}",
        "exec": "~/.scripts/updates",
        "return-type": "json",
        "on-click": "~/.scripts/updates update",
        "interval": 7320,
        "tooltip": true,
        "signal": 4
        // "tooltip-format": "{}",
        // "exec-tooltip": "~/.scripts/updates tooltip"
    },
    "hyprland/window": {
        "format": "{}",
        // "separate-outputs": true,
        // "max-length": 35
    },
    /* "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format": "â†•{bandwidthTotalBytes}",
        "format-disconnected": "{icon} No Internet",
        "format-linked": "ï‍– {ifname} (No IP)",
