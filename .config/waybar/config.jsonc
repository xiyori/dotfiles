        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {volume}%", // {format_source}
        "format-muted": "ï‘¦ ", // {format_source}
        "format-icons": {
            "default": [
                "ï€¦",
                "ï€§",
                "ï€¨"
            ]
        },
        "scroll-step": 5,
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "pavucontrol"
    }, */
    "custom/autogain": {
        // "scroll-step": 1, // %, can be a float
        "format": "{}", // {format_source}
        "tooltip": true,
        "escape": true,
        "exec": "~/.scripts/audio/auto_gain_status.sh",
        "return-type": "json",
        "on-click": "~/.scripts/audio/auto_gain.sh",
        "on-click-right": "~/.scripts/audio/auto_gain.sh reset",
        "on-scroll-up": "~/.scripts/audio/manual_gain.sh up",
        "on-scroll-down": "~/.scripts/audio/manual_gain.sh down",
        "signal": 2
    },
    "custom/soundprofile": {
        // "scroll-step": 1, // %, can be a float
        "format": "{}", // {format_source}
        "tooltip": true,
        "escape": true,
        "exec": "~/.scripts/audio/profile_status.sh",
        "return-type": "json",
        "on-click": "~/.scripts/audio/next_profile.sh",
        "signal": 5
    },
    "custom/sound": {
        // "scroll-step": 1, // %, can be a float
        "format": "{}", // {format_source}
        "tooltip": true,
        "escape": true,
        "exec": "~/.scripts/audio/custom_sound.sh",
        "return-type": "json",
        "on-click": "~/.scripts/audio/control.sh custom_action",  // play-pause or open widget depending on tablet mode
        "on-click-right": "~/.scripts/audio/next_active_sink.sh",
        "on-scroll-up": "~/.scripts/audio/control.sh up quiet",
        "on-scroll-down": "~/.scripts/audio/control.sh down quiet",
        // "interval": 2,
        "signal": 1
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon} {percent}%",
        "tooltip-format": "Brightness {percent}%",
        "format-icons": [
            "îژچ",
            "îڈ“",
            "îڈ‘",
            "îڈڈ",
            "îڈژ",
            "îڈچ",
            "îڈٹ",
            "îڈˆ",
            "îژ›"
        ],
        "on-click": "~/.scripts/brightness.sh custom_action",
        "on-scroll-up": "~/.scripts/brightness.sh up",
        "on-scroll-down": "~/.scripts/brightness.sh down",
        // "interval": 2
        "interval": "once"
    },
    "battery": {
        "states": {
            "good": 100,
            "warning": 30,
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-alt": "{icon} {time}",
        // "format-good": "", // An empty format will hide the module
        "format-full": "َ±ں¢ {capacity}%",
        "format-icons": [
            "َ°پ؛",
            "َ°پ»",
            "َ°پ¼",
            "َ°پ½",
            "َ°پ¾",
            "َ°پ؟",
            "َ°‚€",
            "َ°‚پ",
            "َ°‚‚",
            "َ°پ¹"
        ],
        "interval": 2
    },
    "custom/notifications": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
            "none": "ï‚¢",
            "dnd-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
            "dnd-none": "ï‡·",
            "inhibited-notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
            "inhibited-none": "ï‚¢",
            "dnd-inhibited-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
            "dnd-inhibited-none": "ï‡·"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    /* "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ïپ®",
            "deactivated": "ïپ°"
        }
    }, */
    "tray": {
        "icon-size": 14,
        "spacing": 9
    },
    "clock": {
        "timezone": "",
        "format": "{:%d <small>%a</small> %H:%M}",
        //"format": "ï€— {:%a %b %d %Y | %H:%M}",
        "format-alt": "{:%A %B %d %Y | %r}",
        "tooltip-format": "<tt><small><span color='#f2cdcd'><b>{:%d}</b></span> {calendar}</small></tt>",
        "locale": "ru_RU.utf8",
        "calendar": {
            "weeks-pos"     : "",
            "format": {
                "months":     "<span color='#f2cdcd'><b>{}</b></span>",
                "days":       "<span color='#cdd6f4'><b>{}</b></span>",
                "weekdays":   "<span color='#eba0ac'><b>{}</b></span>",
                "today":      "<span color='#a6e3a1'><b><u>{}</u></b></span>"
            }
        },
        "interval": 1,
        "on-click-right": "alacritty --class \"tty-flex,tty-flex\" -e calcurse"
    },
    "hyprland/language": {
        "format": "{}",
        "format-en": "en",
        "format-ru": "ru",
        //"keyboard-name": "",
        "on-click": "hyprctl switchxkblayout current next"
    },
    "custom/weather": {
        "format": "{}",
        "tooltip": true,
        "exec": "~/.scripts/wttr",
        "on-click": ":",
        "return-type": "json",
        "interval": 7320
    },
    "custom/power": {
        "format": "{}",
        "exec": "echo '{\"text\":\"âڈ»\",\"tooltip\":\"Power\"}'",
        "return-type": "json",
        "on-click": "~/.scripts/logout.sh",
        "on-click-right": "~/.scripts/wallpaper.sh next"
    }
}
